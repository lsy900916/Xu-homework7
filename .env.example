# SQL Server 连接配置（复制为 .env 并填写实际值）
# 使用 python-dotenv 时会在应用启动时自动加载 .env

MSSQL_SERVER=xu-kuhne-projects-test.database.windows.net
MSSQL_DATABASE=usecase1_skill
MSSQL_USERNAME=your_username
MSSQL_PASSWORD=your_password
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# 认证配置
# AUTH_REQUIRED: 是否需要登录认证（true=需要认证，false=无需认证即可访问接口）
# 默认值为 true，设置为 false 可以跳过登录直接访问所有接口（仅用于开发/测试环境）
AUTH_REQUIRED=false

# 大模型配置
# LLM_PROVIDER: 大模型提供商（ollama 或 deepseek）
LLM_PROVIDER=ollama

# Ollama 配置（当 LLM_PROVIDER=ollama 时使用）
# LLM_API_URL: Ollama API地址
LLM_API_URL=http://localhost:11434/v1/chat/completions
# LLM_MODEL: Ollama 模型名称
LLM_MODEL=qwen2.5:3b

# DeepSeek 配置（当 LLM_PROVIDER=deepseek 时使用）
# DEEPSEEK_API_KEY: DeepSeek API密钥（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_API_URL: DeepSeek API地址
DEEPSEEK_API_URL=https://api.deepseek.com
# DEEPSEEK_MODEL: DeepSeek 模型名称
DEEPSEEK_MODEL=deepseek-v4-pro

# 通用配置
# LLM_TEMPERATURE: 温度参数（0-1，越低越确定）
LLM_TEMPERATURE=0.7
# LLM_USE_THOUGHT: 是否启用思考过程（true/false）
LLM_USE_THOUGHT=false
